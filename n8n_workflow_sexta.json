{
  "name": "SaaS Obras - Cron Sexta-feira 16h",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 16 * * 5"
            }
          ]
        }
      },
      "id": "e8334460-1e5b-402a-8d76-52c1e4f3a743",
      "name": "Toda Sexta as 16h",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [ 240, 300 ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://[SEU-SUPABASE-URL]/rest/v1/rpc/obter_obras_pendentes",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "[SUPABASE-KEY]" },
            { "name": "Authorization", "value": "Bearer [SUPABASE-KEY]" }
          ]
        },
        "options": {}
      },
      "id": "abc12345-1e5b-402a-8d76-52c1e4f3a743",
      "name": "Buscar Obras e Perguntas",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [ 460, 300 ]
    },
    {
      "parameters": {
        "fieldToSplitOut": "data",
        "options": {}
      },
      "id": "split_in_batches",
      "name": "Item Lists",
      "type": "n8n-nodes-base.itemLists",
      "typeVersion": 3,
      "position": [ 680, 300 ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.EVOLUTION_API_URL }}/message/sendText/{{ $env.EVOLUTION_INSTANCE }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.EVOLUTION_API_KEY }}" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "number", "value": "={{ $json.telefone }}" },
            { "name": "text", "value": "Olá {{ $json.mestre_obras || 'Mestre' }}! 👷‍♂️\nObra: {{ $json.obra_nome }}\nFase: {{ $json.fase_nome }}\n\nPergunta:\n👉 *{{ $json.pergunta_texto }}*\n\nResponda apenas com *SIM*, *NÃO* ou *N/A*." }
          ]
        },
        "options": {}
      },
      "id": "http_evolution",
      "name": "Enviar WhatsApp (Evolution API)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [ 900, 300 ]
    }
  ],
  "connections": {
    "Toda Sexta as 16h": {
      "main": [ [ { "node": "Buscar Obras e Perguntas", "type": "main", "index": 0 } ] ]
    },
    "Buscar Obras e Perguntas": {
      "main": [ [ { "node": "Item Lists", "type": "main", "index": 0 } ] ]
    },
    "Item Lists": {
      "main": [ [ { "node": "Enviar WhatsApp (Evolution API)", "type": "main", "index": 0 } ] ]
    }
  }
}
