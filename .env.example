# -----------------------------------------------------------------------------
# CONFIGURAÇÕES DO SUPABASE
# -----------------------------------------------------------------------------
# URL do seu projeto Supabase (encontrado em Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://sua-url-do-supabase.supabase.co

# Chave pública anônima do Supabase (encontrada em Settings -> API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-publica-anonima-aqui

# Chave administrativa "service_role" do Supabase
# IMPORTANTE: Mantenha esta chave estritamente confidencial. Utilizada para ignorar RLS nos webhooks.
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role-aqui

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES DA EVOLUTION API (WHATSAPP)
# -----------------------------------------------------------------------------
# URL onde o serviço da Evolution API está rodando (ex: Railway, VPS ou Localhost)
EVOLUTION_API_URL=http://localhost:8080

# Chave de API administrativa definida na instalação da Evolution API
EVOLUTION_API_KEY=sua_apikey_da_evolution

# Nome da instância criada para gerenciar o envio de mensagens (ex: mestre_bot)
EVOLUTION_INSTANCE=instancia_teste

# -----------------------------------------------------------------------------
# SEGURANÇA E TAREFAS AGENDADAS (CRON)
# -----------------------------------------------------------------------------
# Chave secreta para autorizar as execuções de rotas cron administrativas
CRON_SECRET=chave_secreta_padrao_desenvolvimento_123

# -----------------------------------------------------------------------------
# INTEGRAÇÃO GOOGLE SHEETS + LOOKER STUDIO
# -----------------------------------------------------------------------------
# ID da planilha Google Sheets (parte da URL: spreadsheets/d/{ID}/edit)
GOOGLE_SHEETS_ID=seu-id-da-planilha-aqui

# E-mail da Service Account do Google Cloud (ex: nome@projeto.iam.gserviceaccount.com)
# Lembre-se de compartilhar a planilha com este e-mail como Editor!
GOOGLE_SERVICE_ACCOUNT_EMAIL=nome@seu-projeto.iam.gserviceaccount.com

# Chave privada RSA da Service Account (em formato PEM, com \n nos quebras de linha)
# Encontrado no JSON de credenciais baixado do Google Cloud Console (campo "private_key")
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END PRIVATE KEY-----\n"

# -----------------------------------------------------------------------------
# COMO CONFIGURAR O GOOGLE SHEETS (passo a passo):
# 1. Acesse: https://console.cloud.google.com
# 2. Crie um projeto → Ative a API "Google Sheets API"
# 3. Vá em "IAM & Admin" → "Service Accounts" → Crie uma conta de serviço
# 4. Gere e baixe a chave JSON (tipo P12 ou JSON)
# 5. Copie o e-mail e a private_key do JSON para as variáveis acima
# 6. Abra sua planilha no Google Sheets → Compartilhar → Cole o e-mail da Service Account → Editor
# 7. Copie o ID da planilha da URL e cole em GOOGLE_SHEETS_ID
# 8. Chame POST /api/sync/google-sheets (com Authorization: Bearer {CRON_SECRET}) para sincronizar
# -----------------------------------------------------------------------------
